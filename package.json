{
  "name": "randomizers",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "copy-index-to-404": "cp dist/browser/index.html dist/browser/404.html",
    "build:prod": "ng build --configuration production --base-href=https://vortilion.github.io/randomizers/ && npm run copy-index-to-404",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "lint": "ng lint",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.18",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/material": "21.2.14",
    "@angular/platform-browser": "21.2.18",
    "@angular/platform-browser-dynamic": "21.2.18",
    "@angular/router": "21.2.18",
    "@angular/service-worker": "21.2.18",
    "@jsverse/transloco": "^7.5.1",
    "@tailwindcss/postcss": "^4.3.2",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.17",
    "@angular/cli": "21.2.17",
    "@angular/compiler-cli": "21.2.18",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.1.9"
  }
}
